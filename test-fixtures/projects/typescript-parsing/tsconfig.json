{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@models/*": ["src/*"],
      "@fixtures/*": ["src/fixtures/*"]
    },
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*"]
}
